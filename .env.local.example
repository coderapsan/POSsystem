# Example Environment Variables File
# Copy this to .env.local and add your actual Stripe keys

# ============================================
# STRIPE PAYMENT CONFIGURATION
# ============================================

# Stripe Publishable Key (client-side, safe to expose)
# Get from: https://dashboard.stripe.com/apikeys
# Format: pk_test_... (test) or pk_live_... (production)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_51YourStripePublishableKeyHere

# Stripe Secret Key (server-side only, NEVER expose)
# Get from: https://dashboard.stripe.com/apikeys  
# Format: sk_test_... (test) or sk_live_... (production)
STRIPE_SECRET_KEY=sk_test_51YourStripeSecretKeyHere

# Stripe Webhook Secret (optional, for webhook verification)
# Get from: https://dashboard.stripe.com/webhooks
# Format: whsec_...
STRIPE_WEBHOOK_SECRET=whsec_YourWebhookSecretHere

# ============================================
# OTHER EXISTING CONFIGURATION
# ============================================

# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/restaurant

# Google Maps API (if using address autocomplete)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyYourGoogleMapsAPIKey

# ============================================
# NOTES
# ============================================
# 1. NEVER commit this file to git
# 2. Use test keys during development
# 3. Switch to live keys for production
# 4. Restart server after changing values
